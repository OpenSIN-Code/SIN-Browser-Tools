# Environment Variables Template
# Copy this file to .env and fill in values as needed

# ============================================================================
# OPTIONAL: Browser Configuration
# ============================================================================

# Path to custom Chrome/Chromium executable (leave empty for Playwright default)
# SIN_BROWSER_EXECUTABLE=

# Run browser in headless mode (default: true)
# SIN_HEADLESS=true

# Enable stealth mode to avoid bot detection (default: true)
# SIN_STEALTH=true

# Default viewport size
# SIN_VIEWPORT_WIDTH=1280
# SIN_VIEWPORT_HEIGHT=720

# ============================================================================
# OPTIONAL: CDP Connection (for connecting to existing browser)
# ============================================================================

# Connect to existing Chrome via CDP instead of launching new browser
# SIN_CDP_URL=http://localhost:9222

# ============================================================================
# OPTIONAL: Session Persistence
# ============================================================================

# Directory to store session data (cookies, localStorage)
# SIN_SESSION_DIR=./.sin_sessions

# ============================================================================
# OPTIONAL: Tracing / Debugging
# ============================================================================

# Enable tool call tracing (saves to .sin_traces/)
# SIN_TRACE_ENABLED=true

# Directory for trace files
# SIN_TRACE_DIR=./.sin_traces

# ============================================================================
# OPTIONAL: PII Redaction
# ============================================================================

# Enable automatic PII redaction in logs/traces (default: true)
# SIN_PII_REDACTION=true

# ============================================================================
# OPTIONAL: Timeouts (in milliseconds)
# ============================================================================

# Default navigation timeout
# SIN_NAVIGATION_TIMEOUT=30000

# Default action timeout (click, type, etc.)
# SIN_ACTION_TIMEOUT=10000

# ============================================================================
# MCP Server Configuration
# ============================================================================

# Log level for MCP server (DEBUG, INFO, WARNING, ERROR)
# SIN_LOG_LEVEL=INFO
